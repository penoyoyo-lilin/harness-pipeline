.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc

# Go
vendor/
*.exe
*.dll
*.so

# Node
node_modules/

# Build outputs
dist/
build/
coverage/

# Environment
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Logs
*.log

# ─── Harness pipeline 框架本身的运行时产物（不入库）───
# 框架根目录的 .harness/ 是本仓库自己的任务状态（如有）
.harness/logs/
.harness/artifacts/
.harness/reports/
.harness/.gocache/
.harness/playwright/

# 注意：.harness/scripts/ 需入库（profile 脚本由 init.sh 复制到此）
# 注意：stacks/<profile>/scripts/ 需入库（profile 脚本源文件）

# Playwright
.playwright-cli/

# ─── 子项目（独立仓库，不纳入框架仓库）───
# projects/ 下的实际项目有自己的 git 仓库和构建产物，不纳入框架仓库
# 框架仓库只包含：skills/ stacks/ scripts/ docs/ internal/ examples/ 等框架资产
projects/

# 临时文件
*.tmp
*.bak
